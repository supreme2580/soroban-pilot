{
  "name": "@stellarpilot/cli",
  "version": "0.0.1",
  "description": "StellarPilot CLI - Bootstrap and manage Stellar/Soroban applications",
  "type": "module",
  "bin": {
    "stellarpilot": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
