{
  "name": "@stellarpilot/sdk",
  "version": "0.0.1",
  "description": "StellarPilot SDK - Core utilities for Stellar & Soroban development",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./wallet": "./dist/wallet/index.js",
    "./stellar": "./dist/stellar/index.js",
    "./transaction": "./dist/transaction/index.js",
    "./account": "./dist/account/index.js",
    "./asset": "./dist/asset/index.js",
    "./network": "./dist/network/index.js",
    "./error": "./dist/error/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --fix",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
