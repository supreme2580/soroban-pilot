{
  "name": "stellarpilot",
  "version": "0.0.1",
  "private": true,
  "description": "The open-source toolkit for building production-ready Stellar & Soroban applications.",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "cli": "node packages/cli/dist/index.js",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.0.8",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.62.1"
  }
}
